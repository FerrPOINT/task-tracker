{
  "openapi": "3.1.0",
  "info": {
    "title": "Task Tracker API",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [],
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [],
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/issues": {
      "post": {
        "tags": [],
        "operationId": "create_issue",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIssueRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Issue created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateIssueResponse"
                }
              }
            }
          }
        }
      }
    },
    "/issues/{id}": {
      "get": {
        "tags": [],
        "operationId": "get_issue",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Issue id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Issue details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueResponse"
                }
              }
            }
          },
          "404": {
            "description": "Issue not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/projects": {
      "get": {
        "tags": [],
        "operationId": "list_projects",
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/projects/{project_key}/backlog": {
      "get": {
        "tags": [],
        "operationId": "get_backlog",
        "parameters": [
          {
            "name": "project_key",
            "in": "path",
            "description": "Project key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Backlog for project",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BacklogResponse"
                }
              }
            }
          }
        }
      }
    },
    "/projects/{project_key}/board": {
      "get": {
        "tags": [],
        "operationId": "get_board",
        "parameters": [
          {
            "name": "project_key",
            "in": "path",
            "description": "Project key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Board for project",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": [],
        "operationId": "search_issues",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResultResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "required": [
          "token",
          "user"
        ],
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        }
      },
      "BacklogResponse": {
        "type": "object",
        "required": [
          "sprint",
          "sprint_issues",
          "backlog_issues"
        ],
        "properties": {
          "backlog_issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueResponse"
            }
          },
          "sprint": {
            "$ref": "#/components/schemas/SprintResponse"
          },
          "sprint_issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueResponse"
            }
          }
        }
      },
      "BoardColumnResponse": {
        "type": "object",
        "required": [
          "id",
          "name",
          "issue_ids"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "issue_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          },
          "wip_limit": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          }
        }
      },
      "BoardResponse": {
        "type": "object",
        "required": [
          "columns",
          "issues",
          "sprint"
        ],
        "properties": {
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BoardColumnResponse"
            }
          },
          "issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueResponse"
            }
          },
          "sprint": {
            "$ref": "#/components/schemas/SprintResponse"
          }
        }
      },
      "CreateIssueRequest": {
        "type": "object",
        "required": [
          "project_key",
          "issue_type",
          "summary",
          "description",
          "priority",
          "labels"
        ],
        "properties": {
          "assignee_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": "string"
          },
          "due_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "issue_type": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "original_estimate_seconds": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "priority": {
            "type": "string"
          },
          "project_key": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "CreateIssueResponse": {
        "type": "object",
        "required": [
          "issue"
        ],
        "properties": {
          "issue": {
            "$ref": "#/components/schemas/IssueResponse"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Health": {
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "IssueResponse": {
        "type": "object",
        "required": [
          "id",
          "key",
          "summary",
          "description",
          "project_key",
          "project_name",
          "status",
          "reporter_id",
          "reporter_name",
          "priority",
          "labels",
          "time_spent_seconds"
        ],
        "properties": {
          "assignee_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "assignee_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": "string"
          },
          "due_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "original_estimate_seconds": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "priority": {
            "type": "string"
          },
          "project_key": {
            "type": "string"
          },
          "project_name": {
            "type": "string"
          },
          "remaining_estimate_seconds": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "reporter_id": {
            "type": "string"
          },
          "reporter_name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "time_spent_seconds": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ProjectListResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectResponse"
            }
          }
        }
      },
      "ProjectResponse": {
        "type": "object",
        "required": [
          "id",
          "key",
          "name",
          "description",
          "owner_id",
          "created_at",
          "todo_count",
          "in_progress_count",
          "done_count"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "done_count": {
            "type": "integer",
            "format": "int64"
          },
          "id": {
            "type": "string"
          },
          "in_progress_count": {
            "type": "integer",
            "format": "int64"
          },
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "owner_id": {
            "type": "string"
          },
          "todo_count": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "email",
          "password",
          "name"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "SearchResultResponse": {
        "type": "object",
        "required": [
          "issues"
        ],
        "properties": {
          "issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueResponse"
            }
          }
        }
      },
      "SprintResponse": {
        "type": "object",
        "required": [
          "id",
          "name",
          "goal",
          "state",
          "velocity",
          "issue_ids"
        ],
        "properties": {
          "goal": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "issue_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          },
          "remaining_days": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "state": {
            "type": "string"
          },
          "velocity": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "required": [
          "id",
          "email",
          "name"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  }
}